# Copy this file to `.env` for local development.
# Do not commit real secrets.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# When DEBUG=true:
# - enables /debug/graph/* endpoints
# - may log request payloads (prompts can contain user text; use locally only)
DEBUG=false

# OpenAI request timeout (seconds)
OPENAI_REQUEST_TIMEOUT=30

# Word generation (Responses API) tuning
OPENAI_WORD_GEN_MODEL=gpt-4o-mini
WORD_GEN_TIMEOUT=18
WORD_GEN_MIN_CONFIDENCE=0.72

# Optional inference toggles
LEVEL_INFERENCE_USE_LLM=false

# Networking / proxies
OPENAI_TRUST_ENV=false

# Local persistence overrides (optional)
IDEMPOTENCY_DB_PATH=data/idempotency.db
VOCAB_DB_PATH=data/vocab.db

# Logging
LOG_LEVEL=INFO
LOG_VERBOSE=false

