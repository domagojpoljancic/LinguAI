# Copy this file to `.env` for local development.
# Do not commit real secrets.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DEBUG=false
OPENAI_REQUEST_TIMEOUT=30

# Minimal backend configuration supports the same core env vars
# as the repo-root backend; keep values consistent.
LEVEL_INFERENCE_USE_LLM=false
OPENAI_TRUST_ENV=false

LOG_LEVEL=INFO
LOG_VERBOSE=false

